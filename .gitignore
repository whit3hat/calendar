# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node.js (calendar app — Phase 2+) ────────────────────────
node_modules/
npm-debug.log*
.env
.env.*

# ── Credentials — NEVER commit these ─────────────────────────
# Real vdirsyncer config with iCloud password lives at:
#   ~/.config/vdirsyncer/config  (outside the project directory)
# The file below would only appear if someone copies it here by mistake.
config/vdirsyncer.conf.local

# ── Runtime / generated data ──────────────────────────────────
# Local .ics calendar data (synced by vdirsyncer, not source code)
*.ics
*.log

# Exception: sample .ics files used for local Mac development
!app/data/**/*.ics

# Re-exclude UUID-named .ics files inside app/data/ — those are
# auto-generated (POST /api/events writes UUID-named files, and
# pulling from real iCloud during local dev produces them too) and
# may contain private events. The hand-curated samples like
# birthday-party.ics have at most one dash and stay tracked.
app/data/**/*-*-*-*-*.ics
